# ============================================================
# FOOD KWETU — Variables d'environnement
# 1. Copiez ce fichier en .env.local
# 2. Remplissez les valeurs ci-dessous
# ============================================================

# ── Supabase ──
# Trouvez ces valeurs dans : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Email (Gmail) ──
# 1. Activez la validation en 2 étapes sur votre compte Gmail
# 2. Allez dans : Mon compte Google → Sécurité → Mots de passe des applications
# 3. Créez un mot de passe d'application pour "Autre (nom personnalisé)"
GMAIL_USER=votre.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=votre.email@gmail.com

# ── Admin Dashboard ──
# Mot de passe pour accéder à /admin (choisissez un mot de passe fort)
NEXT_PUBLIC_ADMIN_PASSWORD=foodkwetu-admin-2024